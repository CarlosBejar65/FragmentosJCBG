<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:padding="8dp">

    <TextView
        android:id="@+id/pantalla"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.35"
        android:gravity="end|bottom"
        android:padding="24dp"
        android:textColor="@color/text_primary"
        android:textSize="64sp"
        tools:text="12345"
        android:background="@color/surface_dark"
        android:layout_marginBottom="16dp" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.65"
        android:stretchColumns="*">

        <TableRow android:layout_weight="1">
            <Button android:id="@+id/btnBorrar" android:text="@string/btnBorrar" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/error_color" android:textSize="24sp" />
            <Button android:id="@+id/btnSign" android:text="@string/btnSign" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/accent_color" android:textSize="24sp" />
            <Button android:id="@+id/btnPercent" android:text="@string/btnPercent" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/accent_color" android:textSize="24sp" />
            <Button android:id="@+id/btnDivision" android:text="@string/btnDivision" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/accent_color" android:textSize="24sp" />
        </TableRow>

        <TableRow android:layout_weight="1">
            <Button android:id="@+id/btn7" android:text="@string/btn7" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btn8" android:text="@string/btn8" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btn9" android:text="@string/btn9" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btnMultiplicacion" android:text="@string/btnMultiplicacion" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/accent_color" android:textSize="24sp" />
        </TableRow>

        <TableRow android:layout_weight="1">
            <Button android:id="@+id/btn4" android:text="@string/btn4" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btn5" android:text="@string/btn5" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btn6" android:text="@string/btn6" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btnResta" android:text="@string/btnResta" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/accent_color" android:textSize="24sp" />
        </TableRow>

        <TableRow android:layout_weight="1">
            <Button android:id="@+id/btn1" android:text="@string/btn1" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btn2" android:text="@string/btn2" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btn3" android:text="@string/btn3" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btnSuma" android:text="@string/btnSuma" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/accent_color" android:textSize="24sp" />
        </TableRow>

        <TableRow android:layout_weight="1">
            <Button android:id="@+id/btn0" android:layout_span="2" android:text="@string/btn0" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btnDecimal" android:text="@string/btnDecimal" style="@style/Widget.MaterialComponents.Button.TextButton" android:textColor="@color/text_primary" android:textSize="24sp" />
            <Button android:id="@+id/btnIgual" android:text="@string/btnIgual" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" android:backgroundTint="@color/accent_color" android:textColor="@color/bg_main" android:textSize="24sp" />
        </TableRow>
    </TableLayout>
</LinearLayout>